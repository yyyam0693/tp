@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":FindCommandParser" as FindCommandParser LOGIC_COLOR
participant ":ArgumentTokenizer" as ArgumentTokenizer LOGIC_COLOR
participant "argMultimap:ArgumentMultimap" as ArgumentMultimap LOGIC_COLOR
participant ":ParserUtil" as ParserUtil LOGIC_COLOR
participant ":FindMatchType" as FindMatchType LOGIC_COLOR
participant "p:PersonPredicate" as PersonPredicate LOGIC_COLOR
participant "f:FindCommand" as FindCommand LOGIC_COLOR
end box

[-> LogicManager : execute("find ...")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("find ...")
activate AddressBookParser

create FindCommandParser
AddressBookParser -> FindCommandParser
activate FindCommandParser

FindCommandParser -> ArgumentTokenizer : tokenize(" " + args, PREFIX_MATCH_TYPE)
activate ArgumentTokenizer
create ArgumentMultimap
ArgumentTokenizer -> ArgumentMultimap
deactivate ArgumentTokenizer

FindCommandParser -> ArgumentMultimap : verifyNoDuplicatePrefixesFor(PREFIX_MATCH_TYPE)

FindCommandParser -> FindCommandParser : parseFindArgs(argMultimap)
activate FindCommandParser
alt m/ prefix provided
    FindCommandParser -> ArgumentMultimap : getValue(PREFIX_MATCH_TYPE)
    FindCommandParser -> ParserUtil : tokenizeSpaceSeparated(matchTypeArgs)
    FindCommandParser -> FindMatchType : fromToken(matchTypeToken)
    FindMatchType --> FindCommandParser : matchType
    FindCommandParser -> FindCommandParser : build ParsedFindArgs(matchType, keywords)
else m/ prefix not provided
    FindCommandParser -> ArgumentMultimap : getPreamble()
    FindCommandParser -> ParserUtil : tokenizeSpaceSeparated(preamble)
    FindCommandParser -> FindCommandParser : build ParsedFindArgs(KEYWORD, keywords)
end
deactivate FindCommandParser

FindCommandParser -> FindCommandParser : ensure keywords not empty
FindCommandParser -> FindMatchType : createPredicate(keywords)
activate FindMatchType
create PersonPredicate
FindMatchType -> PersonPredicate
deactivate FindMatchType

create FindCommand
FindCommandParser -> FindCommand
activate FindCommand
FindCommand --> FindCommandParser
deactivate FindCommand

FindCommandParser --> AddressBookParser : f
deactivate FindCommandParser
FindCommandParser -[hidden]-> AddressBookParser
destroy FindCommandParser

AddressBookParser --> LogicManager : f
deactivate AddressBookParser

[<--LogicManager
deactivate LogicManager
@enduml
